## ===========================================
## MQTT - broker en Railway (ya configurado)
## ===========================================
MQTT_URL=mqtt://maglev.proxy.rlwy.net:36922
MQTT_USERNAME=announcer
MQTT_PASSWORD=changeme

## ===========================================
## OAuth2 Google - lo creas vos en Google Cloud Console
## ===========================================
## Ver GMAIL_OAUTH_SETUP.md para los pasos
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

## ===========================================
## Encriptacion de refresh_tokens
## ===========================================
## Generar con: openssl rand -base64 32
ENCRYPTION_KEY=base64key32bytes==

## ===========================================
## HTTP server
## ===========================================
HTTP_PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

## ===========================================
## Speaker / IMAP
## ===========================================
SPEAKER_DEVICE_ID=spkr-001
DB_PATH=./_data/db.sqlite

## Allowlist (csv) - opcional, vacio acepta cualquier remitente con parser
ALLOWED_SENDERS=

LOG_LEVEL=info
